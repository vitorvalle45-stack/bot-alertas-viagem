# ==============================================
# CONFIGURACAO DO BOT DE ALERTAS DE VIAGEM
# ==============================================
# 1. Crie seu bot no Telegram: fale com @BotFather
# 2. Copie o token que ele te dar
# 3. Renomeie este arquivo para .env
# 4. Cole o token abaixo

TELEGRAM_BOT_TOKEN=cole_seu_token_aqui

# ID ou username do seu canal (ex: @passagensbaratasbr)
# Para descobrir o ID: adicione o bot @userinfobot ao canal
TELEGRAM_CHANNEL_ID=@seu_canal_aqui

# ID do admin (seu ID pessoal no Telegram)
# Para descobrir: fale com @userinfobot no Telegram
ADMIN_ID=seu_id_numerico_aqui
